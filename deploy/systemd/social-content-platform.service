[Unit]
Description=Social Content Platform Console
After=network.target

[Service]
Type=simple
WorkingDirectory=/var/www/xiao/backend
EnvironmentFile=-/etc/social-content-platform.env
ExecStart=/var/www/xiao/backend/venv/bin/python main.py
Restart=always
RestartSec=3
# Change these to the Linux account that owns the deployment files.
User=deploy
Group=deploy

[Install]
WantedBy=multi-user.target
